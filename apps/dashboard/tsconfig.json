{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "module": "esnext",
        "moduleResolution": "bundler",
        "jsx": "preserve",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@eventos-prime/ui/*": [
                "../../packages/ui/src/*"
            ],
            "@eventos-prime/db": [
                "../../packages/db/src/index.ts"
            ],
            "@eventos-prime/types": [
                "../../packages/types/src/index.ts"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}