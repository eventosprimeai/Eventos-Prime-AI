generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  phone         String?
  avatarUrl     String?
  role          UserRole       @default(STAFF)
  personType    String?
  area          String?
  jobTitle      String?
  category      String?
  contractType  String?
  contractEventId String?
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  evidence      Evidence[]
  gpsLogs       GpsLog[]
  notifications Notification[]
  taskMessages  TaskMessage[]
  assignedTasks Task[]         @relation("TaskAssignee")
  createdTasks  Task[]         @relation("TaskCreator")
  contractEvent Event?         @relation("UserContractEvent", fields: [contractEventId], references: [id])
  voiceNotes    VoiceNote[]
  // Finance relations
  registeredTransactions FinancialTransaction[] @relation("TransactionRegistrar")
  approvedTransactions   FinancialTransaction[] @relation("TransactionApprover")
  bankStatements         BankStatement[]
  generatedDocuments     GeneratedDocument[]
  aiChats                AIChatMessage[]

  @@map("users")
}

model Event {
  id             String          @id @default(uuid())
  name           String
  description    String?
  status         EventStatus     @default(BORRADOR)
  startDate      DateTime
  endDate        DateTime
  location       String?
  venue          String?
  capacity       Int             @default(0)
  budget         Decimal         @default(0) @db.Decimal(12, 2)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  checklists     Checklist[]
  incidents      Incident[]
  sponsorDeals   SponsorDeal[]
  supplierOrders SupplierOrder[]
  tasks          Task[]
  tickets        Ticket[]
  participants   Participant[]
  contractedUsers User[]       @relation("UserContractEvent")
  // Finance relations
  budgetLines    BudgetLine[]
  transactions   FinancialTransaction[]

  @@map("events")
}

model Task {
  id               String        @id @default(uuid())
  title            String
  description      String?
  priority         TaskPriority  @default(MEDIA)
  status           TaskStatus    @default(PENDIENTE)
  dueDate          DateTime?
  completedAt      DateTime?
  isConsulta       Boolean       @default(false)
  evidenceRequired Boolean       @default(true)
  slaHours         Int?
  eventId          String
  assigneeId       String
  creatorId        String
  parentId         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  evidence         Evidence[]
  messages         TaskMessage[]
  assignee         User          @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator          User          @relation("TaskCreator", fields: [creatorId], references: [id])
  event            Event         @relation(fields: [eventId], references: [id])
  parent           Task?         @relation("SubTasks", fields: [parentId], references: [id])
  subtasks         Task[]        @relation("SubTasks")
  voiceNotes       VoiceNote[]

  @@map("tasks")
}

model TaskMessage {
  id        String   @id @default(uuid())
  text      String
  taskId    String
  authorId  String
  readBy    String[] @default([])
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_messages")
}

model Evidence {
  id        String       @id @default(uuid())
  type      EvidenceType
  fileUrl   String
  fileName  String
  fileSize  Int?
  mimeType  String?
  caption   String?
  taskId    String
  userId    String
  createdAt DateTime     @default(now())
  task      Task         @relation(fields: [taskId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@map("evidence")
}

model VoiceNote {
  id               String   @id @default(uuid())
  audioUrl         String
  durationSeconds  Int?
  transcription    String?
  aiInterpretation String?
  processed        Boolean  @default(false)
  taskId           String?
  userId           String
  createdAt        DateTime @default(now())
  task             Task?    @relation(fields: [taskId], references: [id])
  user             User     @relation(fields: [userId], references: [id])

  @@map("voice_notes")
}

model Sponsor {
  id            String        @id @default(uuid())
  companyName   String
  industry      String?
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  website       String?
  notes         String?
  affinityScore Float?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deals         SponsorDeal[]

  @@map("sponsors")
}

model SponsorDeal {
  id            String       @id @default(uuid())
  stage         SponsorStage @default(PROSPECTO)
  dealValue     Decimal?     @db.Decimal(12, 2)
  notes         String?
  sponsorId     String
  eventId       String
  lastContactAt DateTime?
  closedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  event         Event        @relation(fields: [eventId], references: [id])
  sponsor       Sponsor      @relation(fields: [sponsorId], references: [id])

  @@map("sponsor_deals")
}

model Supplier {
  id           String          @id @default(uuid())
  companyName  String
  contactName  String?
  contactEmail String?
  contactPhone String?
  category     String?
  rating       Float?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  orders       SupplierOrder[]
  transactions FinancialTransaction[]

  @@map("suppliers")
}

model SupplierOrder {
  id          String      @id @default(uuid())
  description String
  status      OrderStatus @default(PENDIENTE)
  amount      Decimal?    @db.Decimal(12, 2)
  dueDate     DateTime?
  supplierId  String
  eventId     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  event       Event       @relation(fields: [eventId], references: [id])
  supplier    Supplier    @relation(fields: [supplierId], references: [id])

  @@map("supplier_orders")
}

model Ticket {
  id         String       @id @default(uuid())
  ticketCode String       @unique
  qrCode     String?
  status     TicketStatus @default(RESERVADO)
  buyerName  String
  buyerEmail String
  buyerPhone String?
  ticketType String       @default("GENERAL")
  price      Decimal      @db.Decimal(10, 2)
  eventId    String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  checkins   CheckIn[]
  payment    Payment?
  event      Event        @relation(fields: [eventId], references: [id])

  @@map("tickets")
}

model CheckIn {
  id        String   @id @default(uuid())
  scannedAt DateTime @default(now())
  gate      String?
  notes     String?
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  @@map("checkins")
}

model Payment {
  id          String          @id @default(uuid())
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("USD")
  status      PaymentStatus   @default(PENDIENTE)
  provider    PaymentProvider @default(DATAFAST)
  providerRef String?
  description String?
  ticketId    String          @unique
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  ticket      Ticket          @relation(fields: [ticketId], references: [id])

  @@map("payments")
}

model Checklist {
  id         String          @id @default(uuid())
  name       String
  isTemplate Boolean         @default(false)
  eventId    String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  items      ChecklistItem[]
  event      Event?          @relation(fields: [eventId], references: [id])

  @@map("checklists")
}

model ChecklistItem {
  id          String    @id @default(uuid())
  label       String
  completed   Boolean   @default(false)
  order       Int       @default(0)
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id])

  @@map("checklist_items")
}

model GpsLog {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  accuracy  Float?
  timestamp DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@map("gps_logs")
}

model Incident {
  id          String           @id @default(uuid())
  title       String
  description String?
  severity    IncidentSeverity @default(MEDIA)
  resolved    Boolean          @default(false)
  resolvedAt  DateTime?
  eventId     String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  event       Event            @relation(fields: [eventId], references: [id])

  @@map("incidents")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  read      Boolean  @default(false)
  channel   String   @default("push")
  data      Json?
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  userAgent String?
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum UserRole {
  DIRECTOR
  ADMIN
  COORDINADOR
  STAFF
  PROVEEDOR
  SPONSOR
}

enum EventStatus {
  BORRADOR
  PLANIFICADO
  EN_PLANIFICACION
  PRE_PRODUCCION
  EN_VIVO
  EN_EJECUCION
  POST_PRODUCCION
  POST_EVENTO
  CERRADO
  FINALIZADO
  CANCELADO
}

enum TaskPriority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum TaskStatus {
  PENDIENTE
  EN_PROGRESO
  REVISION
  COMPLETADA
  CANCELADA
}

enum EvidenceType {
  FOTO
  VIDEO
  DOCUMENTO
  AUDIO
}

enum SponsorStage {
  PROSPECTO
  CONTACTADO
  REUNION
  PROPUESTA
  NEGOCIACION
  CERRADO
  PERDIDO
}

enum OrderStatus {
  PENDIENTE
  CONFIRMADO
  EN_TRANSITO
  ENTREGADO
  VERIFICADO
  RECHAZADO
}

enum TicketStatus {
  RESERVADO
  PAGADO
  CHECKIN
  CANCELADO
  REEMBOLSADO
}

enum PaymentStatus {
  PENDIENTE
  PROCESANDO
  COMPLETADO
  FALLIDO
  REEMBOLSADO
}

enum PaymentProvider {
  DATAFAST
  TRANSFERENCIA
  EFECTIVO
}

enum IncidentSeverity {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum ParticipantStage {
  CONTACTADO
  RESPONDIDO
  REUNION_PROGRAMADA
  CONFIRMADO
  CANCELADO
}

model Participant {
  id            String           @id @default(uuid())
  name          String
  type          String?          // INSTITUCION, EMPRESA, PERSONA
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  stage         ParticipantStage @default(CONTACTADO)
  notes         String?
  eventId       String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  event         Event            @relation(fields: [eventId], references: [id])

  @@map("participants")
}

// ═══════════════════════════════════════════════════════════
// FINANCE & ACCOUNTING MODULE
// ═══════════════════════════════════════════════════════════

model FinancialAccount {
  id           String        @id @default(uuid())
  name         String
  type         AccountType
  bankName     String?
  accountNum   String?
  currency     String        @default("USD")
  balance      Decimal       @default(0) @db.Decimal(14, 2)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions FinancialTransaction[]
  bankStatements BankStatement[]

  @@map("financial_accounts")
}

model FinancialTransaction {
  id              String            @id @default(uuid())
  type            TransactionType
  category        String
  subcategory     String?
  description     String
  amount          Decimal           @db.Decimal(14, 2)
  taxAmount       Decimal?          @db.Decimal(14, 2)
  taxRate         Decimal?          @db.Decimal(5, 2)
  date            DateTime
  reference       String?
  status          TransactionStatus @default(REGISTRADO)
  attachmentUrl   String?
  attachmentName  String?
  ocrData         Json?
  accountId       String?
  eventId         String?
  supplierId      String?
  registeredById  String
  approvedById    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  account        FinancialAccount?  @relation(fields: [accountId], references: [id])
  event          Event?             @relation(fields: [eventId], references: [id])
  supplier       Supplier?          @relation(fields: [supplierId], references: [id])
  registeredBy   User               @relation("TransactionRegistrar", fields: [registeredById], references: [id])
  approvedBy     User?              @relation("TransactionApprover", fields: [approvedById], references: [id])

  @@map("financial_transactions")
}

model BudgetLine {
  id          String   @id @default(uuid())
  category    String
  subcategory String?
  planned     Decimal  @db.Decimal(14, 2)
  eventId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event    @relation(fields: [eventId], references: [id])

  @@map("budget_lines")
}

model BankStatement {
  id            String               @id @default(uuid())
  accountId     String
  fileName      String
  fileUrl       String
  period        String
  totalCredits  Decimal?             @db.Decimal(14, 2)
  totalDebits   Decimal?             @db.Decimal(14, 2)
  status        ReconciliationStatus @default(PENDIENTE)
  ocrRawData    Json?
  uploadedById  String
  createdAt     DateTime             @default(now())

  account       FinancialAccount     @relation(fields: [accountId], references: [id])
  uploadedBy    User                 @relation(fields: [uploadedById], references: [id])
  entries       BankStatementEntry[]

  @@map("bank_statements")
}

model BankStatementEntry {
  id              String          @id @default(uuid())
  date            DateTime
  description     String
  amount          Decimal         @db.Decimal(14, 2)
  type            TransactionType
  matched         Boolean         @default(false)
  matchedTransId  String?
  statementId     String
  createdAt       DateTime        @default(now())

  statement       BankStatement   @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@map("bank_statement_entries")
}

model DocumentTemplate {
  id          String             @id @default(uuid())
  name        String
  type        DocumentType
  htmlContent String             @db.Text
  fields      Json
  active      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  generated   GeneratedDocument[]

  @@map("document_templates")
}

model GeneratedDocument {
  id            String           @id @default(uuid())
  templateId    String
  data          Json
  pdfUrl        String?
  sentTo        String?
  sentAt        DateTime?
  generatedById String
  createdAt     DateTime         @default(now())

  template      DocumentTemplate @relation(fields: [templateId], references: [id])
  generatedBy   User             @relation(fields: [generatedById], references: [id])

  @@map("generated_documents")
}

// Finance Enums

enum AccountType {
  BANCARIA
  CAJA
  DIGITAL
}

enum TransactionType {
  INGRESO
  GASTO
  TRANSFERENCIA
}

enum TransactionStatus {
  REGISTRADO
  APROBADO
  ANULADO
}

enum ReconciliationStatus {
  PENDIENTE
  EN_PROCESO
  CONCILIADO
  CON_DIFERENCIAS
}

enum DocumentType {
  FACTURA
  ORDEN_COMPRA
  CONTRATO
  RECIBO
  RETENCION
  OTRO
}

// ═══════════════════════════════════════════════════════════
// AI ASSISTANT CHAT HISTORY
// ═══════════════════════════════════════════════════════════

model AIChatMessage {
  id           String   @id @default(uuid())
  userId       String
  role         String   // "user" | "assistant"
  content      String
  dataAccessed String?  // what data categories were accessed
  wasRestricted Boolean @default(false) // true if data was denied due to permissions
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("ai_chat_messages")
}
