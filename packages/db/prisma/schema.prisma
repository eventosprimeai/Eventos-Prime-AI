// ═══════════════════════════════════════════════════════
//  EventosPrime-AI — Prisma Schema
//  Base de datos PostgreSQL (Supabase + pgvector)
// ═══════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── USUARIOS ────────────────────────────────────────

enum UserRole {
  DIRECTOR
  ADMIN
  COORDINADOR
  STAFF
  PROVEEDOR
  SPONSOR
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  phone     String?
  avatarUrl String?
  role      UserRole @default(STAFF)
  active    Boolean  @default(true)

  // Relaciones
  assignedTasks    Task[]         @relation("TaskAssignee")
  createdTasks     Task[]         @relation("TaskCreator")
  evidence         Evidence[]
  voiceNotes       VoiceNote[]
  notifications    Notification[]
  gpsLogs          GpsLog[]
  auditLogs        AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─── EVENTOS ─────────────────────────────────────────

enum EventStatus {
  BORRADOR
  PLANIFICADO
  PRE_PRODUCCION
  EN_VIVO
  POST_PRODUCCION
  CERRADO
  CANCELADO
}

model Event {
  id          String      @id @default(uuid())
  name        String
  description String?
  status      EventStatus @default(BORRADOR)
  startDate   DateTime
  endDate     DateTime
  location    String?
  venue       String?
  capacity    Int         @default(0)
  budget      Decimal     @default(0) @db.Decimal(12, 2)

  // Relaciones
  tasks           Task[]
  sponsorDeals    SponsorDeal[]
  supplierOrders  SupplierOrder[]
  tickets         Ticket[]
  checklists      Checklist[]
  incidents       Incident[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("events")
}

// ─── TAREAS ──────────────────────────────────────────

enum TaskPriority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum TaskStatus {
  PENDIENTE
  EN_PROGRESO
  REVISION
  COMPLETADA
  CANCELADA
}

model Task {
  id                String       @id @default(uuid())
  title             String
  description       String?
  priority          TaskPriority @default(MEDIA)
  status            TaskStatus   @default(PENDIENTE)
  dueDate           DateTime?
  completedAt       DateTime?
  evidenceRequired  Boolean      @default(true)
  slaHours          Int?

  // Relaciones
  event       Event     @relation(fields: [eventId], references: [id])
  eventId     String
  assignee    User      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId  String
  creator     User      @relation("TaskCreator", fields: [creatorId], references: [id])
  creatorId   String
  parent      Task?     @relation("SubTasks", fields: [parentId], references: [id])
  parentId    String?
  subtasks    Task[]    @relation("SubTasks")

  evidence    Evidence[]
  voiceNotes  VoiceNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

// ─── EVIDENCIA ───────────────────────────────────────

enum EvidenceType {
  FOTO
  VIDEO
  DOCUMENTO
  AUDIO
}

model Evidence {
  id       String       @id @default(uuid())
  type     EvidenceType
  fileUrl  String
  fileName String
  fileSize Int?
  mimeType String?
  caption  String?

  task     Task   @relation(fields: [taskId], references: [id])
  taskId   String
  user     User   @relation(fields: [userId], references: [id])
  userId   String

  createdAt DateTime @default(now())

  @@map("evidence")
}

// ─── NOTAS DE VOZ ────────────────────────────────────

model VoiceNote {
  id              String  @id @default(uuid())
  audioUrl        String
  durationSeconds Int?
  transcription   String?
  aiInterpretation String?
  processed       Boolean @default(false)

  task   Task?   @relation(fields: [taskId], references: [id])
  taskId String?
  user   User    @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())

  @@map("voice_notes")
}

// ─── SPONSORS ────────────────────────────────────────

enum SponsorStage {
  PROSPECTO
  CONTACTADO
  REUNION
  PROPUESTA
  NEGOCIACION
  CERRADO
  PERDIDO
}

model Sponsor {
  id           String @id @default(uuid())
  companyName  String
  industry     String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  website      String?
  notes        String?

  affinityScore Float?
  deals         SponsorDeal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sponsors")
}

model SponsorDeal {
  id         String       @id @default(uuid())
  stage      SponsorStage @default(PROSPECTO)
  dealValue  Decimal?     @db.Decimal(12, 2)
  notes      String?

  sponsor    Sponsor @relation(fields: [sponsorId], references: [id])
  sponsorId  String
  event      Event   @relation(fields: [eventId], references: [id])
  eventId    String

  lastContactAt DateTime?
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("sponsor_deals")
}

// ─── PROVEEDORES ─────────────────────────────────────

enum OrderStatus {
  PENDIENTE
  CONFIRMADO
  EN_TRANSITO
  ENTREGADO
  VERIFICADO
  RECHAZADO
}

model Supplier {
  id           String  @id @default(uuid())
  companyName  String
  contactName  String?
  contactEmail String?
  contactPhone String?
  category     String?
  rating       Float?
  notes        String?

  orders SupplierOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suppliers")
}

model SupplierOrder {
  id          String      @id @default(uuid())
  description String
  status      OrderStatus @default(PENDIENTE)
  amount      Decimal?    @db.Decimal(12, 2)
  dueDate     DateTime?

  supplier   Supplier @relation(fields: [supplierId], references: [id])
  supplierId String
  event      Event    @relation(fields: [eventId], references: [id])
  eventId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("supplier_orders")
}

// ─── TICKETS ─────────────────────────────────────────

enum TicketStatus {
  RESERVADO
  PAGADO
  CHECKIN
  CANCELADO
  REEMBOLSADO
}

model Ticket {
  id         String       @id @default(uuid())
  ticketCode String       @unique
  qrCode     String?
  status     TicketStatus @default(RESERVADO)
  buyerName  String
  buyerEmail String
  buyerPhone String?
  ticketType String       @default("GENERAL")
  price      Decimal      @db.Decimal(10, 2)

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String

  payment  Payment?
  checkins CheckIn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tickets")
}

model CheckIn {
  id        String   @id @default(uuid())
  scannedAt DateTime @default(now())
  gate      String?
  notes     String?

  ticket   Ticket @relation(fields: [ticketId], references: [id])
  ticketId String

  @@map("checkins")
}

// ─── PAGOS ───────────────────────────────────────────

enum PaymentStatus {
  PENDIENTE
  PROCESANDO
  COMPLETADO
  FALLIDO
  REEMBOLSADO
}

enum PaymentProvider {
  DATAFAST
  TRANSFERENCIA
  EFECTIVO
}

model Payment {
  id              String          @id @default(uuid())
  amount          Decimal         @db.Decimal(10, 2)
  currency        String          @default("USD")
  status          PaymentStatus   @default(PENDIENTE)
  provider        PaymentProvider @default(DATAFAST)
  providerRef     String?
  description     String?

  ticket   Ticket @relation(fields: [ticketId], references: [id])
  ticketId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

// ─── CHECKLISTS ──────────────────────────────────────

model Checklist {
  id       String          @id @default(uuid())
  name     String
  isTemplate Boolean       @default(false)

  event    Event?  @relation(fields: [eventId], references: [id])
  eventId  String?

  items    ChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("checklists")
}

model ChecklistItem {
  id        String  @id @default(uuid())
  label     String
  completed Boolean @default(false)
  order     Int     @default(0)

  checklist   Checklist @relation(fields: [checklistId], references: [id])
  checklistId String

  @@map("checklist_items")
}

// ─── GPS / UBICACIÓN ─────────────────────────────────

model GpsLog {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  accuracy  Float?
  timestamp DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@map("gps_logs")
}

// ─── INCIDENTES ──────────────────────────────────────

enum IncidentSeverity {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

model Incident {
  id          String           @id @default(uuid())
  title       String
  description String?
  severity    IncidentSeverity @default(MEDIA)
  resolved    Boolean          @default(false)
  resolvedAt  DateTime?

  event   Event  @relation(fields: [eventId], references: [id])
  eventId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("incidents")
}

// ─── NOTIFICACIONES ──────────────────────────────────

model Notification {
  id      String  @id @default(uuid())
  title   String
  message String
  read    Boolean @default(false)
  channel String  @default("push")
  data    Json?

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())

  @@map("notifications")
}

// ─── AUDITORÍA ───────────────────────────────────────

model AuditLog {
  id        String  @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  changes   Json?
  ipAddress String?
  userAgent String?

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  createdAt DateTime @default(now())

  @@map("audit_logs")
}
